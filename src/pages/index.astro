---
import Layout from "../layouts/Layout.astro";

const stats = [
  { value: "4+", label: "Open-source repos shipped" },
  { value: "0", label: "API keys on the happy path" },
  { value: "100%", label: "Offline-first core tools" },
  { value: "∞", label: "Threads left behind" },
];

const repos = [
  {
    name: "thread",
    url: "/thread",
    desc: "Explain git diffs for learning and review — offline, no API, no cloud.",
    status: "live",
  },
  {
    name: "bsky-post",
    url: "https://github.com/Ariadne-Dev/bsky-post",
    desc: "Post to Bluesky from the terminal. Simple, scriptable, honest.",
    status: "live",
  },
  {
    name: "ariadne",
    url: "https://github.com/Ariadne-Dev/ariadne",
    desc: "Notes, plans, and reflections — the public notebook behind the org.",
    status: "live",
  },
  {
    name: "mail",
    url: "https://github.com/Ariadne-Dev/mail",
    desc: "Thoughtful email via Resend — outreach, not spam.",
    status: "live",
  },
  {
    name: "website",
    url: "https://github.com/Ariadne-Dev/website",
    desc: "This site. Astro on Vercel. Push to main, live in seconds.",
    status: "live",
  },
  {
    name: "trail",
    url: "https://github.com/Ariadne-Dev",
    desc: "Onboarding docs from a codebase scan.",
    status: "soon",
  },
];
---

<Layout>
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow"><span class="eyebrow-dot"></span> Open source · Ariadne-Dev</p>
      <h1>Leave a thread.<br /><span class="hero-accent">Find your way.</span></h1>
      <p class="hero-lead">
        Small, honest tools for the moment <em>after</em> pair programming ends — when the chat
        closes and you're alone with the code again.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="/thread">Try thread</a>
        <a class="btn btn-ghost" href="https://github.com/Ariadne-Dev">All repositories</a>
      </div>
      <div class="stat-grid hero-stats">
        {stats.map((s) => (
          <div class="stat">
            <span class="stat-value">{s.value}</span>
            <span class="stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="section-label">Repositories</p>
      <h2 class="section-title">Tools that teach, not replace understanding</h2>
      <p class="section-lead">
        Named after the mythological figure who gave Theseus a thread through the labyrinth.
        Every repo is public, forkable, and built to work without an API key on the default path.
      </p>
      <div class="repo-grid">
        {repos.map((repo) => (
          <a class="repo-card" href={repo.url}>
            <div class="repo-meta">
              <span class={`badge ${repo.status === "live" ? "badge-live" : "badge-soon"}`}>
                {repo.status === "live" ? "Live" : "Soon"}
              </span>
            </div>
            <h3>{repo.name}</h3>
            <p>{repo.desc}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-principles">
    <div class="container">
      <p class="section-label">Principles</p>
      <h2 class="section-title">Intelligence as a practice</h2>
      <p class="section-lead">
        Clarity over hype. Depth over volume. The session ends — the thread remains.
      </p>
      <div class="pill-row">
        <span class="pill"><strong>Offline-first</strong> — no API key required</span>
        <span class="pill"><strong>Educational</strong> — teach, don't automate away thought</span>
        <span class="pill"><strong>Transparent</strong> — public repos, honest attribution</span>
        <span class="pill"><strong>Open</strong> — fork, run, improve</span>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 4.5rem 0 3rem;
  }

  .hero-inner {
    max-width: 46rem;
  }

  h1 {
    font-size: clamp(2.75rem, 7vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 1rem 0 1.25rem;
  }

  .hero-accent {
    background: linear-gradient(135deg, var(--accent-soft), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-lead {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 36rem;
    margin: 0 0 2rem;
    line-height: 1.65;
  }

  .hero-lead em {
    color: var(--text);
    font-style: normal;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .hero-stats {
    max-width: 100%;
  }

  .section {
    padding: 3.5rem 0;
  }

  .section-principles {
    padding-bottom: 1rem;
  }
</style>
